<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Intelligent Triage Assistant</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen p-8">

    <h1 class="text-3xl font-bold text-slate-900">Intelligent Triage Assistant</h1>
    <p class="text-slate-500 mt-1 mb-6">Automated analysis of {{ results|length }} support conversations</p>

    <div class="space-y-6">
        {% for item in results %}
            <div class="bg-white rounded-lg shadow-sm flex overflow-hidden">

                <div class="flex-1 p-6 border-r border-slate-100">
                    <div class="text-xs text-slate-400">{{ item.chat.chat_id }}</div>
                    <div class="font-semibold text-slate-800 mb-4">{{ item.chat.customer_name }}</div>

                    <div class="space-y-2">
                        {% for message in item.chat.messages %}
                            {% if message.role == 'user' %}
                                <div class="bg-blue-50 text-slate-800 text-sm rounded-2xl px-4 py-2 ml-auto max-w-[85%] w-fit">
                                    {{ message.content }}
                                </div>
                            {% else %}
                                <div class="bg-slate-100 text-slate-800 text-sm rounded-2xl px-4 py-2 max-w-[85%] w-fit">
                                    {{ message.content }}
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>

                <div class="flex-1 p-6 bg-slate-50">
                    {% if item.error %}
                        <div class="bg-red-50 text-red-700 text-sm rounded-md p-4">
                            (!) Could not analyze this chat: {{ item.error }}
                        </div>
                    {% else %}
                        {% set sentimentColors = {
                            'POSITIVE':   'bg-green-100 text-green-800',
                            'NEUTRAL':    'bg-slate-200 text-slate-700',
                            'NEGATIVE':   'bg-red-100 text-red-800',
                            'FRUSTRATED': 'bg-amber-100 text-amber-800'
                        } %}

                        <div class="flex flex-wrap gap-2 mb-4">
                            <span class="text-xs font-semibold px-3 py-1 rounded-full bg-indigo-100 text-indigo-800">
                                {{ item.analysis.category.value }}
                            </span>
                            <span class="text-xs font-semibold px-3 py-1 rounded-full {{ sentimentColors[item.analysis.sentiment.value] }}">
                                {{ item.analysis.sentiment.value }}
                            </span>
                            <span class="text-xs font-semibold px-3 py-1 rounded-full {{ item.analysis.urgency >= 4 ? 'bg-red-100 text-red-800' : 'bg-slate-100 text-slate-600' }}">
                                Urgency {{ item.analysis.urgency }}/5
                            </span>
                        </div>

                        <p class="text-sm text-slate-700 mb-4">
                            <span class="font-semibold">Summary:</span> {{ item.analysis.summary }}
                        </p>

                        <p class="text-sm font-semibold text-slate-700 mb-1">Suggested reply:</p>
                        <div class="bg-white border border-slate-200 rounded-md p-3 text-sm text-slate-700">
                            {{ item.analysis.suggestedReply }}
                        </div>
                    {% endif %}
                </div>

            </div>
        {% endfor %}
    </div>

</body>
</html>